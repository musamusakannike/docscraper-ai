APP_URL="https://docscraper.codiac.online"

# BROWSER_WS_ENDPOINT: WebSocket endpoint for a remote headless browser service.
# Used as a fallback when scraping Cloudflare-protected documentation sites.
# In local dev, the app uses your local Chrome installation instead.
# Services: Browserless (wss://chrome.browserless.io?token=YOUR_TOKEN),
#           BrowserBase, or any Puppeteer-compatible WS endpoint.
BROWSER_WS_ENDPOINT="wss://chrome.browserless.io?token=YOUR_TOKEN"
